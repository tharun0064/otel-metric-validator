# ---- Oracle connection (the same DB the collector monitors) ----
# The monitoring user the receiver connects as needs SELECT on the V$ views.
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREEPDB1
ORACLE_MONITORING_USER=nrmon
ORACLE_MONITORING_PASSWORD=MonTest123

# ---- What the collector ingested ----
# Path the validator reads to learn the emitted metric values.
#  - otlp-json : newline-delimited OTLP JSON written by a `file` exporter (recommended)
#  - debug-log : text from the `debug`/`logging` exporter (e.g. `docker logs otel-collector > out.log`)
VALIDATOR_INGEST_PATH=/shared/otel-metrics.json
VALIDATOR_INGEST_FORMAT=otlp-json

# pdb : receiver connected straight to a PDB (uses v$sysstat)        -> no oracle.db.pdb attr
# cdb : receiver connected to CDB root (uses v$con_sysstat, per-PDB) -> oracle.db.pdb attr present
VALIDATOR_CONTAINER_MODE=pdb

# Thick mode: set to 1 if the DB server enforces Native Network Encryption (NNE).
# Thin mode (the default) cannot negotiate NNE and fails with DPY-3001. Thick mode
# needs an Oracle Instant Client; point ORACLE_CLIENT_LIB_DIR at it if it isn't on
# the default library path (setting the dir implies thick mode).
VALIDATOR_ORACLE_THICK=0
# ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient_23_5

# ---- NRQL ingest check (only needed with --check-ingest) ----
# Verifies NR's cumulative->delta conversion: sum(metric) in NRDB should equal the
# emitted cumulative end-to-end difference. Needs a NerdGraph (user) API key.
NEW_RELIC_API_KEY=
NEW_RELIC_ACCOUNT_ID=
# prod: https://api.newrelic.com/graphql   staging: https://staging-api.newrelic.com/graphql
NEW_RELIC_NERDGRAPH_URL=https://api.newrelic.com/graphql

# ---- Comparison tuning ----
VALIDATOR_TOLERANCE_GAUGE=0.02      # 2% relative tolerance for gauges
VALIDATOR_TOLERANCE_COUNTER=0.05    # 5% relative tolerance for cumulative counters (absorbs scrape/probe drift)
VALIDATOR_ABS_EPSILON=1             # absolute tolerance used when the expected value is ~0
VALIDATOR_WATCH_INTERVAL=30         # seconds between cycles in --watch mode
